# Non-secret config and any secrets NOT stored in 1Password live here.
# Secrets sourced from 1Password (LLM_AUTH_TOKEN, WORDPRESS_CLIENT_SECRET,
# WORDPRESS_APPLICATION_PASSWORD, GITHUB_WORDPRESS_TOKEN) are resolved at
# runtime by `fnox exec` — see fnox.toml.

# Slack Configuration (not in 1Password yet)
SLACK_BOT_TOKEN=xoxb-...-...-...
SLACK_APP_TOKEN=xapp-1-...-...-...

# LiteLLM proxy (LITELLM_API_KEY not in 1Password yet)
LITELLM_API_KEY=sk-..._..._...
LITELLM_API_BASE=https://litellm.sbp.ai/

# AI Assistant Configuration
ASSISTANT_MODEL=azure/gpt-5-mini
ASSISTANT_SYSTEM_PROMPT="You are a helpful Slack assistant. Provide concise, friendly responses."

# Blog module LLM config (LLM_AUTH_TOKEN injected by fnox)
LLM_BASE_URL=https://litellm.sbp.ai/
LLM_DEFAULT_MODEL=azure/gpt-5-mini

# Blog module WordPress config (WORDPRESS_APPLICATION_PASSWORD and
# WORDPRESS_CLIENT_SECRET injected by fnox)
WORDPRESS_USERNAME=bot@leosimons.com
WORDPRESS_CLIENT_ID=...
WORDPRESS_SITE_ID=...
